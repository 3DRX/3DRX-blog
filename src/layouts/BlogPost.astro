---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import type { ImageMetadata } from "astro";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{jpeg,jpg,png,gif,svg}",
);

function preprocessHeroImage(heroImage: string | undefined) {
  if (!heroImage) {
    return { heroImageSrc: undefined, heroImageIsUrl: false };
  }
  let heroImageSrc: string | undefined = heroImage;
  let heroImageIsUrl = false;
  if (heroImage.startsWith("http")) {
    if (heroImage.startsWith("https://source.unsplash.com/")) {
      // Unsplash images from url is not available anymore
      // TODO: call the Unsplash API to get the image
      heroImageSrc = undefined;
    }
    heroImageIsUrl = true;
  } else {
    if (!images[heroImage]) {
      throw new Error(
        `"${heroImage}" does not exist in glob: "/src/assets/**/*.{jpeg,jpg,png,gif,svg}"`,
      );
    }
  }
  return { heroImageSrc, heroImageIsUrl };
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const { heroImageSrc, heroImageIsUrl } = preprocessHeroImage(heroImage);
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script src="../LoadGiscus.ts"></script>
    <link
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <article>
        {
          heroImageSrc &&
            (heroImageIsUrl ? (
              <Image
                width={720}
                height={360}
                src={heroImageSrc}
                alt=""
                loading="eager"
              />
            ) : (
              <Image
                class="mx-auto w-4/5 border border-line"
                src={images[heroImageSrc]()}
                alt=""
                loading="eager"
              />
            ))
        }
        <p class="mt-6 font-mono text-xs tracking-widest text-faint uppercase">
          // post
        </p>
        <h1
          class="mt-1 font-sans text-4xl leading-tight font-black tracking-tighter"
        >
          {title}
        </h1>
        <p class="mt-1 text-faint">{description}</p>
        <div
          class="mt-4 mb-8 flex border-y-2 border-ink py-2 font-mono text-xs tracking-widest text-faint uppercase"
        >
          <FormattedDate date={pubDate} />
          <div class="grow"></div>
          {
            updatedDate && (
              <div>
                Updated <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        <div
          class="prose max-w-full text-ink prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-ink prose-h1:text-xl prose-p:text-justify prose-a:text-accent prose-a:underline prose-a:underline-offset-4 prose-blockquote:not-italic prose-blockquote:border-l-accent prose-blockquote:text-faint prose-strong:text-ink prose-code:bg-code-bg prose-code:px-1 prose-code:py-0.5 prose-code:font-normal prose-code:text-ink prose-code:before:content-none prose-code:after:content-none prose-pre:border prose-pre:border-line prose-pre:bg-paper-raised prose-ul:mt-0 prose-li:my-0 prose-img:mx-auto prose-img:rounded-none prose-img:border prose-img:border-line prose-hr:border-line"
        >
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
