---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

// should be: Record<string, () => Promise<{default: ImageMetadata}>>
// instead: Record<string, () => Promise<unknown>>
// use any to avoid ts being angry
const images: any = import.meta.glob(
  "/src/assets/photography/*.{jpeg,jpg,png,gif}",
);
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script src="../LoadGiscus.ts"></script>
  </head>

  <body>
    <Header />
    <main>
      <article>
        {
          heroImage && (
            <Image
              class="mx-auto my-2 block h-auto max-h-[80vh] w-auto max-w-[min(28rem,80vw)] border border-line"
              src={images[`/src/assets/photography/${heroImage}`]()}
              alt=""
              loading="eager"
              transition:name={`cover-${title}`}
            />
          )
        }
        <p class="mt-6 font-mono text-xs tracking-widest text-faint uppercase">
          // photography
        </p>
        <h1
          class="mt-1 font-sans text-4xl leading-tight font-black tracking-tighter"
        >
          {title}
        </h1>
        <p class="mt-1 text-faint">{description}</p>
        <div
          class="mt-4 mb-8 flex border-y-2 border-ink py-2 font-mono text-xs tracking-widest text-faint uppercase"
        >
          <FormattedDate date={pubDate} />
          <div class="grow"></div>
          {
            updatedDate && (
              <div>
                Updated <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
        <div
          class="prose max-w-full text-ink prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-ink prose-h1:text-xl prose-p:text-justify prose-a:text-accent prose-a:underline prose-a:underline-offset-4 prose-strong:text-ink prose-ul:mt-0 prose-li:my-0 prose-img:mx-auto prose-img:max-h-[calc(100vh-50px)] prose-img:w-auto prose-img:max-w-[calc(100%-20px)] prose-img:rounded-none prose-img:border prose-img:border-line prose-img:pt-10"
        >
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
