---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <p class="font-mono text-xs tracking-widest text-faint uppercase">
        // error — page not found
      </p>
      <h1
        class="font-sans text-[clamp(6rem,30vw,14rem)] leading-none font-black tracking-tighter"
      >
        4<span class="text-accent">0</span>4
      </h1>
      <p class="mt-2 font-mono text-sm text-faint" id="countdown">
        Redirecting in 5 seconds...
      </p>
      <script>
        var count = 5;
        var counter = setInterval(timer, 1000);
        function timer() {
          count = count - 1;
          if (count <= 0) {
            clearInterval(counter);
            window.location.href = "/";
            return;
          }
          const obj = document.getElementById("countdown");
          if (obj)
            obj.innerHTML = `Redirecting in ${count} ${
              count === 1 ? "second" : "seconds"
            }...`;
        }
      </script>
    </main>
    <Footer />
  </body>
</html>
