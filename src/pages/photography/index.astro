---
import { fade } from "astro:transitions";
import { Image } from "astro:assets";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("photography")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// should be: Record<string, () => Promise<{default: ImageMetadata}>>
// instead: Record<string, () => Promise<unknown>>
// @ts-ignore don't know if this is a bug or not
const images: Record<string, () => Promise<{ default: ImageMetadata }>> =
  import.meta.glob("/src/assets/photography/*.{jpeg,jpg,png,gif}");
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main transition:animate={fade({ duration: "0.2s" })}>
      <section>
        <div class="mb-4 flex items-baseline justify-between">
          <h2 class="font-sans text-2xl font-black tracking-tighter uppercase">
            Photography
          </h2>
          <span class="font-mono text-xs tracking-widest text-faint">
            {posts.length} SERIES
          </span>
        </div>
        <ul class="border-t-2 border-ink">
          {
            posts.map((post) => (
              <li class="border-b border-line">
                <a
                  href={`/photography/${post.id}/`}
                  class="group -mx-2 flex items-center gap-6 px-2 py-5"
                >
                  <div class="photo-thumb w-32 min-w-32 md:w-80 md:min-w-80">
                    <Image
                      class="w-full origin-top-left border border-line transition-transform duration-300 ease-out will-change-transform md:group-hover:scale-[1.2]"
                      src={images[
                        `/src/assets/photography/${post.data.heroImage}`
                      ]()}
                      alt={post.data.title}
                      loading="eager"
                      decoding="async"
                      transition:name={`cover-${post.data.title}`}
                    />
                  </div>
                  <div class="grow" />
                  <div class="flex flex-col gap-1 text-right">
                    <h3 class="font-sans text-xl font-bold tracking-tight md:text-2xl">
                      {post.data.title}
                    </h3>
                    <p class="text-xs text-faint md:text-sm">
                      {post.data.description}
                    </p>
                    <p class="font-mono text-xs tracking-widest text-faint uppercase">
                      <FormattedDate date={post.data.pubDate} />
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
    <script>
      function initPhotoHover() {
        // desktop only: matches the md: scale transition on the thumbnails
        if (!window.matchMedia("(min-width: 48rem)").matches) return;
        document
          .querySelectorAll<HTMLDivElement>(".photo-thumb")
          .forEach((thumb) => {
            const link = thumb.closest("a");
            const img = thumb.querySelector("img");
            if (!link || !img) return;
            let anim = null;
            const SCALE = 1.2;
            const animateHeight = (to) => {
              const from = thumb.getBoundingClientRect().height;
              if (anim) anim.cancel();
              anim = thumb.animate(
                [{ height: `${from}px` }, { height: `${to}px` }],
                {
                  duration: 300,
                  easing: "cubic-bezier(0, 0, 0.2, 1)",
                  fill: "forwards",
                },
              );
            };
            link.addEventListener("mouseenter", () => {
              // offsetHeight ignores transforms, so this is the natural height
              animateHeight(img.offsetHeight * SCALE);
            });
            link.addEventListener("mouseleave", () => {
              animateHeight(img.offsetHeight);
            });
          });
      }
      initPhotoHover();
      document.addEventListener("astro:after-swap", initPhotoHover);
    </script>
  </body>
</html>
