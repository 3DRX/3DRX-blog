---
const { id } = Astro.props;
---

<script src="./ThemeIcon.ts"></script>
<label class="theme-switch" aria-label="Switch theme">
  <input id={id} class="theme-toggle" type="checkbox" />
  <span class="cell day">日</span>
  <span class="cell night">夜</span>
</label>
<style>
  .theme-switch {
    display: inline-flex;
    border: 1px solid var(--ink);
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    cursor: pointer;
    user-select: none;
  }
  .theme-toggle {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .theme-switch .cell {
    padding: 4px 7px;
    color: var(--faint);
    transition:
      background-color 0.15s,
      color 0.15s;
  }
  .theme-toggle:not(:checked) ~ .day {
    background: var(--ink);
    color: var(--paper);
  }
  .theme-toggle:checked ~ .night {
    background: var(--ink);
    color: var(--paper);
  }
  .theme-switch:hover .cell {
    color: var(--accent);
  }
  .theme-toggle:not(:checked):hover ~ .day,
  .theme-toggle:checked:hover ~ .night {
    color: var(--paper);
  }
</style>
