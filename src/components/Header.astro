---
import { Image } from "astro:assets";
import HeaderLink from "./HeaderLink.astro";
import ThemeIcon from "./ThemeIcon.astro";
import GithubIcon from "../assets/github.svg";
import RSSIcon from "../assets/rss.svg";

const socials = [
  { href: "https://github.com/3DRX/", icon: GithubIcon, alt: "GitHub" },
  { href: "/rss.xml", icon: RSSIcon, alt: "RSS" },
];
---

<header class="mb-8 border-b-2 border-ink pb-4">
  <div class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-2">
    <a
      href="/"
      class="font-sans text-3xl font-black tracking-tighter text-ink no-underline hover:text-ink"
    >
      3DRX<span class="text-accent">■</span>
    </a>
    <nav class="flex items-baseline gap-5">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/photography">Photo</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </nav>
  </div>
  <div class="mt-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener"
            class="opacity-60 transition-opacity hover:opacity-100"
          >
            <Image
              class="h-[1em] w-auto"
              src={s.icon}
              alt={s.alt}
              loading="eager"
              style={{ filter: "invert(var(--invert-value))" }}
            />
          </a>
        ))
      }
    </div>
    <ThemeIcon id="theme" />
  </div>
</header>
