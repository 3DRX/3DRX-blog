---
const { prev, next } = Astro.props;
---

<nav
  class="mt-10 grid grid-cols-3 gap-4 border-y border-line py-3 font-mono text-xs tracking-widest"
>
  <div class="text-left">
    {
      prev !== null && (
        <a href={`/blog/${prev.slug}`} class="text-faint hover:text-accent">
          ← {prev.title}
        </a>
      )
    }
  </div>
  <div class="text-center">
    <a href="/blog" class="text-faint hover:text-accent">cd ..</a>
  </div>
  <div class="text-right">
    {
      next !== null && (
        <a href={`/blog/${next.slug}`} class="text-faint hover:text-accent">
          {next.title} →
        </a>
      )
    }
  </div>
</nav>
